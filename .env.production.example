# =============================================================================
# .env.production (REFERÊNCIA) — Negócio Express (front-end)
# -----------------------------------------------------------------------------
# Copie estas chaves para Vercel → Project → Settings → Environment Variables
# (escopo Production, e Preview se quiser testar branches).
# NÃO commite valores reais. Variáveis NEXT_PUBLIC_* vão para o bundle do
# navegador (são públicas); as demais ficam só no servidor (serverless).
# =============================================================================

# -- API .NET ----------------------------------------------------------------
# URL base da API, SEM prefixo /api e SEM barra final (ver openapi.json).
# OBRIGATÓRIO ser HTTPS em produção: o site na Vercel é HTTPS e chamadas a
# HTTP são bloqueadas por mixed content. A API precisa estar publicada e
# liberar o domínio da Vercel no CORS.
NEXT_PUBLIC_API_URL=https://api.seu-dominio.com.br

# -- Azure Blob Storage (server-side: rota /api/uploads) ---------------------
# SEM prefixo NEXT_PUBLIC_ — fica só no servidor. Marque como "Secret" na Vercel.
# O container precisa estar com acesso público = Blob para exibir as imagens.
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER="productimages"

# -- Asaas (opcional) --------------------------------------------------------
# Só se for tokenizar cartão no front. Se vazio, o fluxo de cartão tokenizado
# fica desativado (ASAAS_ENABLED = false em checkout/asaas.ts).
# NEXT_PUBLIC_ASAAS_TOKENIZE_URL=https://...
