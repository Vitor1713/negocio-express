# URL base da API .NET do Negócio Express (sem prefixo /api; ver openapi.json)
NEXT_PUBLIC_API_URL=http://localhost:5248

# Azure Blob Storage — upload de imagens de produto (server-side, /api/uploads).
# SEM prefixo NEXT_PUBLIC_ (fica só no servidor). Container com acesso público = Blob.
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER="product-images"
